{
  "manifest_version": 3,
  "name": "Primed Listening",
  "version": "1.0.0",
  "description": "Auto-pause video before each subtitle line so you can anticipate it, then resume.",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Primed Listening"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "file://*/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
